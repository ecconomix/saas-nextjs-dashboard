#!/usr/bin/env sh

# Get the current branch name
current_branch=$(git rev-parse --abbrev-ref HEAD)

# Check if trying to push to main branch
if [ "$current_branch" = "main" ]; then
    echo "❌ ERROR: Direct pushes to the 'main' branch are not allowed!"
    echo ""
    echo "Please use the following workflow instead:"
    echo "1. Create a feature branch: git checkout -b feature/your-feature-name"
    echo "2. Make your changes and commit them"
    echo "3. Push your feature branch: git push origin feature/your-feature-name"
    echo "4. Create a pull request to merge into main"
    echo ""
    exit 1
fi

echo "✅ Push to branch '$current_branch' is allowed."